generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL") // uses connection pooling
  directUrl = env("POSTGRES_URL_NON_POOLING") // uses a direct connection
}

model Location {
  id          String   @id @default(cuid())
  address     String   @unique
  orders      Order[]
  coordinates Float[]  @default([0, 0])
  createdAt   DateTime @default(now()) @map(name: "created_at")
  updatedAt   DateTime @updatedAt @map(name: "updated_at")
}

model Order {
  id         String   @id @default(cuid())
  externalId String   @default("") @map(name: "external_id")
  tip        Int?
  total      Int?
  location   Location @relation(fields: [locationId], references: [id])
  locationId String   @default("") @map(name: "location_id")
  createdBy  String   @map(name: "created_by")
  createdAt  DateTime @default(now()) @map(name: "created_at")
  updatedAt  DateTime @updatedAt @map(name: "updated_at")

  @@unique([createdBy, externalId])
}

model AppUser {
  id           String         @id @default(cuid())
  displayName  String?        @map(name: "display_name")
  primaryEmail String?        @map(name: "primary_email")
  identities   AuthIdentity[]
  createdAt    DateTime       @default(now()) @map(name: "created_at")
  updatedAt    DateTime       @updatedAt @map(name: "updated_at")

  @@map(name: "app_users")
}

model AuthIdentity {
  id              String   @id @default(cuid())
  user            AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String   @map(name: "user_id")
  provider        String
  providerSubject String   @map(name: "provider_subject")
  email           String?
  displayName     String?  @map(name: "display_name")
  createdAt       DateTime @default(now()) @map(name: "created_at")
  updatedAt       DateTime @updatedAt @map(name: "updated_at")

  @@unique([provider, providerSubject])
  @@index([userId])
  @@map(name: "auth_identities")
}

model AppStoreEntitlement {
  id                    String    @id @default(cuid())
  driverId              String    @map(name: "driver_id")
  productId             String    @map(name: "product_id")
  transactionId         String    @unique @map(name: "transaction_id")
  originalTransactionId String    @map(name: "original_transaction_id")
  environment           String
  purchasedAt           DateTime  @map(name: "purchased_at")
  revokedAt             DateTime? @map(name: "revoked_at")
  createdAt             DateTime  @default(now()) @map(name: "created_at")
  updatedAt             DateTime  @updatedAt @map(name: "updated_at")

  @@unique([driverId, productId])
  @@index([driverId])
}
